---
import { platforms, type Platform } from '../data/platforms';

interface Props {
  platform: Platform | string;
}

const { platform } = Astro.props;
const p = platforms[platform as Platform] || { label: platform, short: platform, color: 'inherit', bg: 'transparent', border: 'var(--border)' };
---
<span class="badge" style={`color: ${p.color}; background: ${p.bg}; border: 1px solid ${p.border};`}>
  {p.label}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
    font-size: 0.7rem;
    font-weight: 500;
  }
</style>
