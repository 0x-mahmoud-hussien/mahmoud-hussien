---
import PlatformBadge from './PlatformBadge.astro';
import DifficultyBadge from './DifficultyBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  writeup: CollectionEntry<'writeups'>;
}

const { writeup } = Astro.props;
const { title, description, date, platform, difficulty, category, tags } = writeup.data;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC'
}).format(date);
---
<div class="writeup-card-wrapper" data-platform={platform} data-category={category}>
  <a href={`/writeups/${writeup.id}`} class="writeup-card">
    <div class="card-header">
      <h3 class="title">{title}</h3>
      <span class="date">{formattedDate}</span>
    </div>
    
    <div class="meta-row">
      <PlatformBadge platform={platform} />
      <span class="dot">·</span>
      <DifficultyBadge difficulty={difficulty} />
      <span class="dot">·</span>
      <span class="category">{category}</span>
    </div>

    <p class="description">{description}</p>
    
    <div class="tags">
      {tags.slice(0,4).map((tag: string) => <span class="tag">#{tag}</span>)}
    </div>
  </a>
</div>

<style>
  .writeup-card-wrapper {
    margin-bottom: 1rem;
  }
  .writeup-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    color: inherit;
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: all 0.15s ease;
  }
  .writeup-card:hover {
    background: var(--accent-muted);
    border-left-color: var(--accent);
    border-top-color: var(--border-hover);
    border-right-color: var(--border-hover);
    border-bottom-color: var(--border-hover);
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .title {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0;
  }
  .writeup-card:hover .title {
    color: var(--accent);
  }
  .date {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.75rem;
  }
  .dot {
    color: var(--text-tertiary);
  }
  .category {
    color: var(--text-secondary);
  }

  .description {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin: 0 0 1rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 0.7rem;
    color: var(--text-tertiary);
  }
</style>
