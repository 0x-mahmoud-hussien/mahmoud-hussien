---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';
---

<BaseLayout title="Contact" description="Get in touch with Mahmoud Hussien">
  <section class="contact-section">
    <h1 class="section-label">// contact</h1>
    <p class="intro">
      The best way to reach me is via LinkedIn or email. 
      You can also check out my profiles on various cybersecurity training platforms 
      to see my active progress.
    </p>

    <div class="links-list">
      <a href={`mailto:${profile.social.email}`} class="contact-row">
        <span class="icon">✉</span>
        <span class="platform">Email</span>
        <span class="handle">{profile.social.email}</span>
      </a>
      
      <a href={profile.social.linkedin} target="_blank" rel="noopener noreferrer" class="contact-row">
        <span class="icon">🔗</span>
        <span class="platform">LinkedIn</span>
        <span class="handle">Connect</span>
      </a>

      <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="contact-row">
        <span class="icon">{'>_'}</span>
        <span class="platform">GitHub</span>
        <span class="handle">Code & Projects</span>
      </a>

      <a href={profile.social.tryhackme} target="_blank" rel="noopener noreferrer" class="contact-row">
        <span class="icon">⚔️</span>
        <span class="platform">TryHackMe</span>
        <span class="handle">Profile</span>
      </a>

      <a href={profile.social.cyberdefenders} target="_blank" rel="noopener noreferrer" class="contact-row">
        <span class="icon">🛡️</span>
        <span class="platform">CyberDefenders</span>
        <span class="handle">Profile</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .section-label {
    margin-bottom: 2rem;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .intro {
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .links-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-row {
    display: flex;
    align-items: center;
    padding: 1.25rem 1.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    border-left: 3px solid transparent;
    transition: all 0.15s ease;
    text-decoration: none;
    color: var(--text-primary);
  }

  .contact-row:hover {
    background: var(--accent-muted);
    border-left-color: var(--accent);
    border-top-color: var(--border-hover);
    border-right-color: var(--border-hover);
    border-bottom-color: var(--border-hover);
  }

  .icon {
    display: inline-block;
    width: 30px;
    color: var(--accent);
    font-weight: 700;
  }

  .platform {
    width: 150px;
    font-weight: 500;
  }

  .handle {
    color: var(--text-secondary);
  }

  .contact-row:hover .handle {
    color: var(--text-primary);
  }
</style>
