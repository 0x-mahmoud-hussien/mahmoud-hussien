---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlatformBadge from '../../components/PlatformBadge.astro';
import DifficultyBadge from '../../components/DifficultyBadge.astro';
import SkillTag from '../../components/SkillTag.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const writeups = await getCollection('writeups');
  return writeups.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, date, platform, difficulty, category, tags, tools, room_url } = entry.data;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC'
}).format(date);
---

<BaseLayout 
  title={`${title} — Writeup`}
  description={description}
  type="article"
  publishedDate={date}
>
  <div class="writeup-container">
    <a href="/writeups" class="back-link">← writeups</a>
    
    <header class="writeup-header">
      <h1 class="title">{title}</h1>
      
      <div class="meta-row">
        <PlatformBadge platform={platform} />
        <span class="divider">·</span>
        <DifficultyBadge difficulty={difficulty} />
        <span class="divider">·</span>
        <span class="date">{formattedDate}</span>
        <span class="divider">·</span>
        <span class="category">{category}</span>
      </div>

      <div class="tags">
        {tags.map((tag: string) => <span class="tag">#{tag}</span>)}
      </div>

      {tools && tools.length > 0 && (
        <div class="tools-row">
          <span class="tools-label">Tools used:</span>
          <div class="tools-list">
            {tools.map((tool: string) => <SkillTag name={tool} />)}
          </div>
        </div>
      )}

      {room_url && (
        <div class="room-link-container">
          <a href={room_url} target="_blank" rel="noopener noreferrer" class="room-link">→ View original challenge</a>
        </div>
      )}
    </header>

    <hr class="header-divider" />

    <article class="markdown-content">
      <Content />
    </article>
  </div>
</BaseLayout>
<script>
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  const setupWriteupLightbox = () => {
    const container = document.querySelector('.markdown-content');
    if (!container || container.dataset.lightboxInitialized === 'true') {
      return;
    }

    const images = container.querySelectorAll('img');
    images.forEach((img) => {
      const existingLink = img.closest('a');
      if (existingLink) {
        existingLink.classList.add('glightbox');
        existingLink.dataset.gallery = 'writeup-gallery';
        if (!existingLink.getAttribute('href')) {
          existingLink.setAttribute('href', img.currentSrc || img.src);
        }
        return;
      }

      const link = document.createElement('a');
      link.href = img.currentSrc || img.src;
      link.className = 'glightbox';
      link.dataset.gallery = 'writeup-gallery';
      if (img.alt) {
        link.dataset.title = img.alt;
      }

      img.parentNode?.insertBefore(link, img);
      link.appendChild(img);
    });

    GLightbox({
      selector: '.markdown-content a.glightbox',
      touchNavigation: true,
      loop: true,
    });

    container.dataset.lightboxInitialized = 'true';
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupWriteupLightbox, { once: true });
  } else {
    setupWriteupLightbox();
  }
</script>

<style>
  /* ─── FIX 1: Container محتاج padding على كل الشاشات ─── */
  .writeup-container {
    width: 100%;
    max-width: 850px;
    margin: 0 auto;
    padding: 0 1rem;       /* padding دايماً موجود على كل الشاشات */
    box-sizing: border-box;
    overflow-x: hidden;    /* يمنع أي overflow أفقي */
  }

  @media (min-width: 768px) {
    .writeup-container {
      padding: 0 1.5rem;   /* padding أكبر شوية على الـ desktop بدل ما يتمسح */
    }
  }

  @media (min-width: 1024px) {
    .writeup-container {
      padding: 0 2rem;
    }
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .writeup-header {
    margin-bottom: 2rem;
  }

  .title {
    margin-bottom: 1rem;
    line-height: 1.2;
    /* FIX 2: كلمات طويلة في العنوان متكسرش على الموبايل */
    word-break: break-word;
    overflow-wrap: break-word;
  }

  /* ─── FIX 3: meta-row يتعامل صح مع الموبايل ─── */
  .meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;   /* gap أقل في الارتفاع عشان ما يبقاش في مسافات كبيرة */
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
  }

  /* على الموبايل الـ dividers تتخبى لما الـ items تنزل لسطر تاني */
  @media (max-width: 480px) {
    .divider {
      display: none;
    }
    .meta-row {
      gap: 0.4rem 0.6rem;
    }
  }

  .divider {
    color: var(--text-tertiary);
  }

  .date {
    color: var(--text-secondary);
  }

  .category {
    color: var(--text-secondary);
  }

  .tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  .tools-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .tools-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .tools-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .room-link-container {
    margin-top: 1.5rem;
  }

  .room-link {
    font-size: 0.85rem;
    font-weight: 500;
  }

  .header-divider {
    border: 0;
    border-top: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  /* ─── FIX 4: markdown-content تمنع overflow ─── */
  .markdown-content {
    line-height: 1.8;
    width: 100%;
    overflow-x: hidden;     /* أي حاجة أعرض من الشاشة متسببش scroll أفقي */
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .markdown-content :global(h2) {
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-size: 1.4rem;
    text-transform: none;
    letter-spacing: normal;
    word-break: break-word;
  }

  .markdown-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    word-break: break-word;
  }

  .markdown-content :global(p) {
    margin-bottom: 1.5rem;
  }

  /* ─── FIX 5: code blocks تاخد scroll أفقي بدل ما تكسر الـ layout ─── */
  .markdown-content :global(pre) {
    margin: 1.5rem 0;
    overflow-x: auto;       /* scroll أفقي داخل الـ code block بس */
    max-width: 100%;
    /* على الموبايل padding أصغر */
    padding: 1rem;
    box-sizing: border-box;
  }

  .markdown-content :global(code) {
    word-break: break-all;  /* inline code ينكسر لو طويل */
  }

  .markdown-content :global(pre code) {
    word-break: normal;     /* لكن داخل code block خليه يتسكرول */
  }

  /* ─── FIX 6: الصور تملا عرض الشاشة بشكل صح على الموبايل ─── */
  .markdown-content :global(img) {
    display: block;
    width: 100%;            /* اتغير من auto لـ 100% عشان تملا العرض */
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    border-radius: 8px;
    border: 1px solid var(--border);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.28);
    cursor: zoom-in;
    box-sizing: border-box;
  }

  .markdown-content :global(a.glightbox) {
    display: block;
    text-decoration: none;
    width: 100%;            /* الـ link يملا العرض عشان الصورة تملاه كمان */
  }

  /* ─── FIX 7: tables على الموبايل ─── */
  .markdown-content :global(table) {
    width: auto;            /* ياخد العرض اللي محتاجه بس، مش يتمدد */
    min-width: 0;
    max-width: 100%;
    display: block;
    overflow-x: auto;       /* لو الجدول كبير يعمل scroll داخلي */
    -webkit-overflow-scrolling: touch;
    margin: 1.5rem 0;
  }

  .markdown-content :global(ul),
  .markdown-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .markdown-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .markdown-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    background: var(--bg-surface);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    color: var(--text-secondary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    /* على الموبايل متعدش الحدود */
    box-sizing: border-box;
    max-width: 100%;
  }
  
  .markdown-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
</style>