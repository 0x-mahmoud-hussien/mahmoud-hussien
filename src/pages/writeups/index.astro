---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import WriteupCard from '../../components/WriteupCard.astro';
import FilterBar from '../../components/FilterBar.astro';

const allWriteups = await getCollection('writeups');
const publishedWriteups = allWriteups
  .filter(w => !w.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Writeups" description="All my cybersecurity writeups and lab completions.">
  <section class="writeups-header">
    <h1 class="section-label">// all writeups ({publishedWriteups.length})</h1>
  </section>

  <FilterBar />

  <div class="writeups-grid">
    {publishedWriteups.map(writeup => (
      <WriteupCard writeup={writeup} />
    ))}
  </div>
</BaseLayout>

<style>
  .section-label {
    margin-bottom: 2rem;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
</style>
